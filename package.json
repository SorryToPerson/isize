{
  "name": "isize",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first icon generation workspace for web, app, and backend services.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @isize/web",
    "dev:app": "npm run start --workspace @isize/app",
    "dev:server": "npm run start:dev --workspace @isize/server",
    "build:web": "npm run build --workspace @isize/web",
    "build:app": "npm run export:web --workspace @isize/app",
    "build:server": "npm run build --workspace @isize/server",
    "build:contracts": "npm run build --workspace @isize/contracts"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
